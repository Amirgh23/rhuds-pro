{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/__tests__"],
  "references": [
    { "path": "../core" },
    { "path": "../frames" },
    { "path": "../backgrounds" },
    { "path": "../webgl" },
    { "path": "../hooks" }
  ]
}
