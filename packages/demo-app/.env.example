# Monitoring Configuration

# Sentry Configuration
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=1.0.0-phase6

# Google Analytics Configuration
VITE_GA_ID=G-XXXXXXXXXX

# Logging Configuration
VITE_LOG_ENDPOINT=/api/logs
VITE_LOG_LEVEL=info

# Alert Configuration
VITE_ALERT_EMAIL=alerts@example.com
VITE_ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
VITE_ALERT_PAGERDUTY_KEY=your-pagerduty-key

# Performance Monitoring
VITE_PERFORMANCE_TRACKING_ENABLED=true
VITE_MEMORY_TRACKING_ENABLED=true
VITE_NETWORK_TRACKING_ENABLED=true

# Feature Flags
VITE_ENABLE_SENTRY=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_LOGGING=true
VITE_ENABLE_ALERTS=true
