{
  "name": "@rhuds/hooks",
  "version": "0.1.0",
  "description": "RHUDS Hooks - Custom React hooks for RHUDS",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^4.0.0",
    "@types/react": "^18.0.0",
    "jest": "^29.0.0",
    "@testing-library/react": "^14.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  }
}
